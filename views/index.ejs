<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OfficeSpace | System Rezerwacji Zasobów</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #003d99 100%);
            color: white;
            padding: 60px 0;
            margin-bottom: 40px;
            border-radius: 0 0 2rem 2rem;
        }
        .card {
            border: none;
            transition: transform 0.2s, box-shadow 0.2s;
            border-radius: 15px;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
        .icon-box {
            width: 50px;
            height: 50px;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            margin-bottom: 15px;
        }
        .badge-custom {
            padding: 5px 12px;
            border-radius: 20px;
            font-weight: 500;
        }
        .section-title {
            font-weight: 700;
            color: #212529;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body>

    <header class="hero-section shadow">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-3"><i class="bi bi-building-check"></i> OfficeSpace</h1>
            <p class="lead mb-0">Inteligentny system rezerwacji biurek i sal konferencyjnych w Twoim biurze.</p>
        </div>
    </header>

    <main class="container">
        
        <section class="mb-5">
            <h2 class="section-title"><i class="bi bi-door-open text-primary"></i> Sale Konferencyjne</h2>
            <div class="row g-4">
                <% if (rooms.length === 0) { %>
                    <div class="col-12"><div class="alert alert-light">Brak dostępnych sal.</div></div>
                <% } %>
                <% rooms.forEach(room => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div class="icon-box">
                                        <i class="bi bi-people-fill fs-4"></i>
                                    </div>
                                    <span class="badge bg-primary badge-custom">Piętro <%= room.floor %></span>
                                </div>
                                <h5 class="card-title fw-bold"><%= room.name %></h5>
                                <p class="text-muted small">Idealna na spotkania zespołowe i prezentacje.</p>
                                <hr class="text-muted opacity-25">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-secondary">
                                        <i class="bi bi-person-workspace me-1"></i> <%= room.capacity %> miejsc
                                    </span>
                                    <span class="small text-secondary">
                                        <i class="bi bi-projector me-1"></i> <%= room.hasProjector ? 'Rzutnik' : 'Brak' %>
                                    </span>
                                </div>
                                <a href="/details.html?type=room&id=<%= room.id %>" class="btn btn-primary w-100 mt-3 rounded-pill">
                                    Sprawdź dostępność
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>

        <section class="mb-5">
            <h2 class="section-title"><i class="bi bi-pc-display-horizontal text-primary"></i> Stanowiska Pracy</h2>
            <div class="row g-3">
                <% if (desks.length === 0) { %>
                    <div class="col-12"><div class="alert alert-light">Brak dostępnych biurek.</div></div>
                <% } %>
                <% desks.forEach(desk => { %>
                    <div class="col-sm-6 col-md-4 col-lg-3">
                        <div class="card shadow-sm border-start border-primary border-4">
                            <div class="card-body">
                                <h6 class="fw-bold mb-1">Biurko <%= desk.identifier %></h6>
                                <p class="text-muted x-small mb-3" style="font-size: 0.8rem;">
                                    <i class="bi bi-info-circle"></i> <%= desk.equipment || 'Standardowe wyposażenie' %>
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <% if(desk.isStandingDesk) { %>
                                        <span class="badge bg-success-subtle text-success small">Regulowane</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-muted small">Stałe</span>
                                    <% } %>
                                    <a href="/details.html?type=desk&id=<%= desk.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        Rezerwuj
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>

    </main>

    <footer class="py-4 mt-5 bg-white border-top">
        <div class="container text-center text-muted small">
            &copy; 2026 OfficeSpace Project - Techniki WWW
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>